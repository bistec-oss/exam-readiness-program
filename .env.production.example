# Production environment — used by both podman quadlets via EnvironmentFile=
# (resolves to ~/srv/exam-readiness/exam-ready.env on this server).
#
# Generated by scripts/setup-podman.sh on first run; do not hand-edit the
# SESSION_SECRET or POSTGRES_PASSWORD values. Both are rotated by re-running
# setup-podman.sh.
NODE_ENV=production
PORT=3010

# Database — the host name `db` resolves to the exam-ready-db container
# on the exam-ready podman internal network (see podman/exam-ready.network).
DATABASE_URL=postgresql://examready:CHANGE_ME_DB_PASSWORD@db:5432/examready

# Shared by the db quadlet (postgres:16-alpine POSTGRES_PASSWORD) and the
# app quadlet (DATABASE_URL).
POSTGRES_PASSWORD=CHANGE_ME_ROTATE_WITH_SETUP_PODMAN_SH

# Auth (generate with: openssl rand -base64 32)
SESSION_SECRET=REPLACE_WITH_OUTPUT_OF_OPENSSL_RAND_BASE64_32

# Set to 1 after the first successful `podman exec exam-ready-app npx tsx prisma/seed.ts`.
# Re-runs of setup-podman.sh / deploy-podman.sh will not re-seed once this is set.
EXAMREADY_SEEDED=
