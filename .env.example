# Database
POSTGRES_PASSWORD=changeme_strong_password
DATABASE_URL=postgresql://examready:changeme_strong_password@db:5432/examready

# Auth (generate with: openssl rand -base64 32)
SESSION_SECRET=replace_with_32_byte_random_secret

# Cloudflare Tunnel token (from: cloudflared tunnel create exam-ready)
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here
