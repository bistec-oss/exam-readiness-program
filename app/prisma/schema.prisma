generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  CANDIDATE
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum QuestionType {
  MCQ
  TRUE_FALSE
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  name          String
  role          Role           @default(CANDIDATE)
  status        UserStatus     @default(ACTIVE)
  xp            Int            @default(0)
  leaderboardOptIn Boolean     @default(false)
  weeklyEmailOptIn Boolean     @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  attempts      Attempt[]
  mockAttempts  MockAttempt[]
  cohortMembers CohortMember[]
  emailLogs     EmailLog[]
}

model EmailLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  subject   String
  body      String
  createdAt DateTime @default(now())
}

model Cohort {
  id        String         @id @default(cuid())
  name      String
  code      String         @unique
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  members   CohortMember[]
}

model CohortMember {
  id        String   @id @default(cuid())
  cohortId  String
  cohort    Cohort   @relation(fields: [cohortId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt  DateTime @default(now())

  @@unique([cohortId, userId])
}

model Exam {
  id              String         @id @default(cuid())
  name            String
  description     String
  passingScore    Int
  durationMinutes Int            @default(90)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  challengeSets   ChallengeSet[]
  questions       Question[]
  mockAttempts    MockAttempt[]
}

model ChallengeSet {
  id        String     @id @default(cuid())
  title     String
  topic     String
  xpReward  Int        @default(50)
  examId    String
  exam      Exam       @relation(fields: [examId], references: [id], onDelete: Cascade)
  questions Question[]
  attempts  Attempt[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Question {
  id              String        @id @default(cuid())
  text            String
  preamble        String?
  type            QuestionType  @default(MCQ)
  options         Json
  correctOptionId String
  explanation     String
  challengeSetId  String?
  challengeSet    ChallengeSet? @relation(fields: [challengeSetId], references: [id], onDelete: SetNull)
  examId          String
  exam            Exam          @relation(fields: [examId], references: [id], onDelete: Cascade)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Attempt {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  challengeSetId String
  challengeSet   ChallengeSet @relation(fields: [challengeSetId], references: [id], onDelete: Cascade)
  answers        Json
  score          Int
  total          Int
  xpEarned       Int
  idempotencyKey String?      @unique
  completedAt    DateTime     @default(now())
}

model MockAttempt {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  examId      String
  exam        Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  answers     Json
  score       Int
  total       Int
  timeUsed    Int
  startedAt   DateTime
  completedAt DateTime @default(now())
}
